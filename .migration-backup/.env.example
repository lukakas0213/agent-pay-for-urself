APP_ENV=local
LOG_LEVEL=INFO

# Never commit real credentials.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_DATA_COLLECTION_MODEL=gpt-5.4-mini
OPENAI_DATA_ANALYSIS_MODEL=gpt-5.5
OPENAI_RISK_MANAGEMENT_MODEL=gpt-5.5
OPENAI_BUY_SELL_MODEL=gpt-5.5
OPENAI_ORDER_EXECUTION_MODEL=gpt-5.4-mini
OPENAI_LOG_EVALUATION_MODEL=gpt-5.4-mini
OPENAI_TIMEOUT_SECONDS=30
ANTHROPIC_API_KEY=
BROKER_API_KEY=
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agent_pay_for_urself
REDIS_URL=redis://localhost:6379/0

MARKET_DATA_PROVIDER=yahoo

# Broker adapter selection:
# - noop: do not submit broker orders
# - kis_mock: Korea Investment mock-investment overseas order submission
BROKER_ADAPTER=noop

# Required only when BROKER_ADAPTER=kis_mock.
KIS_MOCK_APP_KEY=
KIS_MOCK_APP_SECRET=
KIS_MOCK_ACCOUNT_NUMBER=
KIS_MOCK_ACCOUNT_PRODUCT_CODE=01

# Optional KIS mock submission settings.
KIS_MOCK_BASE_URL=https://openapivts.koreainvestment.com:29443
KIS_MOCK_CONTACT_PHONE=
KIS_MOCK_MANAGEMENT_ORDER_NUMBER=
KIS_MOCK_ORDER_SERVER_DIVISION_CODE=0
KIS_MOCK_ORDER_DIVISION_CODE=00
KIS_MOCK_TIMEOUT_SECONDS=10

EXPERIMENT_STORE_PATH=data/experiments.json
EXPERIMENT_LIVE_ORDER_ENABLED=false

# Cloudflare Pages frontend build-time API base URL. Leave empty for local dev.
NEXT_PUBLIC_API_BASE_URL=
